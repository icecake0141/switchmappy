<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Debug - SwitchMappy</title>
  <link rel="stylesheet" href="/switchmap.css" />
</head>
<body>
  <header class="page-header">
    <div>
      <h1>Debug</h1>
      <p>Generated at {{ build_date.isoformat() }}</p>
    </div>
    <div class="summary-strip" aria-label="Debug summary">
      <div class="summary-item">
        <span class="summary-value">{{ debug.summary.switches }}</span>
        <span class="summary-label">switches</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ debug.summary.ports }}</span>
        <span class="summary-label">ports</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ debug.summary.switch_macs }}</span>
        <span class="summary-label">macs</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ debug.summary.endpoint_correlations }}</span>
        <span class="summary-label">endpoints</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ debug.summary.anomalies }}</span>
        <span class="summary-label">anomalies</span>
      </div>
    </div>
  </header>

  <nav class="quick-links" aria-label="Report sections">
    <ul>
      <li><a href="/index.html">Home</a></li>
      <li><a href="/ports/index.html">Ports</a></li>
      <li><a href="/endpoints/index.html">Endpoints</a></li>
      <li><a href="/vlans/index.html">VLANs</a></li>
      <li><a href="/search/index.html">Search</a></li>
    </ul>
  </nav>

  <section class="panel">
    <h2>Build</h2>
    <dl class="debug-kv">
      <dt>Generated</dt>
      <dd>{{ debug.build.generated_at }}</dd>
      <dt>Output directory</dt>
      <dd>{{ debug.build.output_directory }}</dd>
      <dt>History directory</dt>
      <dd>{{ debug.build.history_directory }}</dd>
      <dt>Failed switches</dt>
      <dd>{{ debug.summary.failed_switches }}</dd>
    </dl>
  </section>

  {% if debug.build.failed_switches %}
  <section class="panel panel-warning">
    <h2>Failed Switches</h2>
    <table>
      <thead>
        <tr>
          <th>Switch</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        {% for switch_name in debug.build.failed_switches %}
        <tr>
          <td>{{ switch_name }}</td>
          <td>{{ debug.build.failed_switch_reasons.get(switch_name, '') }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <section class="panel">
    <h2>Switch Summary</h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Switch</th>
            <th>Management IP</th>
            <th>Vendor</th>
            <th>Ports</th>
            <th>Active</th>
            <th>MACs</th>
            <th>VLANs</th>
            <th>Neighbors</th>
            <th>Endpoints</th>
          </tr>
        </thead>
        <tbody>
          {% for switch in debug.switches %}
          <tr>
            <td>{{ switch.name }}</td>
            <td>{{ switch.management_ip }}</td>
            <td>{{ switch.vendor }}</td>
            <td>{{ switch.ports }}</td>
            <td>{{ switch.active_ports }}</td>
            <td>{{ switch.macs }}</td>
            <td>{{ switch.vlans }}</td>
            <td>{{ switch.neighbors }}</td>
            <td>{{ switch.endpoints }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <h2>Correlation Trace</h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Hostname</th>
            <th>IP</th>
            <th>MAC</th>
            <th>Vendor</th>
            <th>Switch</th>
            <th>Port</th>
            <th>Source</th>
            <th>Warning</th>
          </tr>
        </thead>
        <tbody>
          {% for row in debug.correlation_trace %}
          <tr>
            <td>{{ row.hostname }}</td>
            <td>{{ row.ip }}</td>
            <td>{{ row.mac }}</td>
            <td>{{ row.vendor }}</td>
            <td>{{ row.switch }}</td>
            <td>{{ row.port }}</td>
            <td>{{ row.source }}</td>
            <td>{{ row.warning }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <h2>Unmatched Inputs</h2>
    <div class="debug-grid">
      <div>
        <h3>MAC list not found on switches</h3>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Hostname</th>
                <th>IP</th>
                <th>MAC</th>
                <th>Reason</th>
              </tr>
            </thead>
            <tbody>
              {% for row in debug.unmatched_maclist %}
              <tr>
                <td>{{ row.hostname or '' }}</td>
                <td>{{ row.ip or '' }}</td>
                <td>{{ row.mac }}</td>
                <td>{{ row.reason }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      <div>
        <h3>Switch MACs missing from MAC list</h3>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>MAC</th>
                <th>Reason</th>
              </tr>
            </thead>
            <tbody>
              {% for row in debug.unmatched_switch_macs %}
              <tr>
                <td>{{ row.mac }}</td>
                <td>{{ row.reason }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="panel">
    <h2>Anomalies</h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Severity</th>
            <th>Type</th>
            <th>Switch</th>
            <th>Port</th>
            <th>VLAN</th>
            <th>MACs</th>
            <th>Endpoints</th>
            <th>Neighbors</th>
          </tr>
        </thead>
        <tbody>
          {% for row in debug.anomalies %}
          <tr>
            <td>{{ row.severity }}</td>
            <td>{{ row.type }}</td>
            <td>{{ row.switch }}</td>
            <td>{{ row.port }}</td>
            <td>{{ row.vlan }}</td>
            <td>{{ row.mac_count }}</td>
            <td>{{ row.correlated_endpoint_count }}</td>
            <td>{{ row.neighbor_count }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <h2>Port Debug</h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Switch</th>
            <th>Port</th>
            <th>Description</th>
            <th>Admin</th>
            <th>Oper</th>
            <th>VLAN</th>
            <th>Duplex</th>
            <th>Speed</th>
            <th>Last Change</th>
            <th>MACs</th>
            <th>Endpoints</th>
            <th>Neighbors</th>
            <th>Trunk</th>
            <th>Unused</th>
            <th>In Err</th>
            <th>Out Err</th>
          </tr>
        </thead>
        <tbody>
          {% for row in debug.ports %}
          <tr>
            <td>{{ row.switch }}</td>
            <td>{{ row.port }}</td>
            <td>{{ row.description }}</td>
            <td>{{ row.admin_status }}</td>
            <td>{{ row.oper_status }}</td>
            <td>{{ row.vlan }}</td>
            <td>{{ row.duplex }}</td>
            <td>{{ row.speed or '' }}</td>
            <td>{{ row.last_change }}</td>
            <td>{{ row.mac_count }}</td>
            <td>{{ row.correlated_endpoint_count }}</td>
            <td>{{ row.neighbor_count }}</td>
            <td>{{ row.is_trunk }}</td>
            <td>{{ row.is_unused }}</td>
            <td>{{ row.input_errors or '' }}</td>
            <td>{{ row.output_errors or '' }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</body>
</html>

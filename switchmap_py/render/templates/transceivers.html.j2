<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Transceivers - SwitchMappy</title>
  <link rel="stylesheet" href="/switchmap.css" />
</head>
<body>
  {% from "navigation.html.j2" import report_nav %}
  <header>
    <h1>Transceivers</h1>
    <p>Generated at {{ build_date.isoformat() }}</p>
  </header>
  {{ report_nav('transceivers') }}
  {% set rendered = namespace(count=0) %}
  {% for switch in switches %}
    {% set ports = switch.ports | selectattr('transceiver_model') | list %}
    {% set tx_ports = switch.ports | selectattr('transceiver_tx_power_dbm') | list %}
    {% set rx_ports = switch.ports | selectattr('transceiver_rx_power_dbm') | list %}
    {% set current_ports = switch.ports | selectattr('transceiver_current_ma') | list %}
    {% set transceiver_ports = (ports + tx_ports + rx_ports + current_ports) | unique(attribute='name') | list %}
    {% if transceiver_ports %}
    {% set rendered.count = rendered.count + transceiver_ports | length %}
    <section>
      <h2><a href="/switches/{{ switch.name }}.html">{{ switch.name }}</a></h2>
      <table>
        <thead>
          <tr>
            <th>Switch</th>
            <th>Port</th>
            <th>Description</th>
            <th>Media</th>
            <th>Optic</th>
            <th>Tx dBm</th>
            <th>Rx dBm</th>
            <th>Current mA</th>
            <th>Oper</th>
            <th>Speed</th>
            <th>Neighbor</th>
          </tr>
        </thead>
        <tbody>
          {% for port in transceiver_ports %}
          <tr>
            <td><a href="/switches/{{ switch.name }}.html">{{ switch.name }}</a></td>
            <td><a href="/switches/{{ switch.name }}.html#port-{{ port.name | replace('/', '-') | replace(' ', '-') | replace('.', '-') }}">{{ port.name }}</a></td>
            <td>{{ port.descr }}</td>
            <td>{{ port.media or '' }}</td>
            <td>{{ port.transceiver_model or '' }}</td>
            <td>{{ port.transceiver_tx_power_dbm if port.transceiver_tx_power_dbm is not none else '' }}</td>
            <td>{{ port.transceiver_rx_power_dbm if port.transceiver_rx_power_dbm is not none else '' }}</td>
            <td>{{ port.transceiver_current_ma if port.transceiver_current_ma is not none else '' }}</td>
            <td>{{ port.oper_status }}</td>
            <td>{{ port.speed or '' }}</td>
            <td>
              {% for neighbor in port.neighbors %}
                <div>{{ neighbor.display_name }}</div>
              {% endfor %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>
    {% endif %}
  {% endfor %}
  {% if rendered.count == 0 %}
  <p>No transceiver diagnostics collected.</p>
  {% endif %}
</body>
</html>

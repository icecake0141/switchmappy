<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>SwitchMappy</title>
  <link rel="stylesheet" href="/switchmap.css" />
</head>
<body>
  <header class="page-header">
    <div>
      <h1>SwitchMappy</h1>
      <p>Generated at {{ build_date.isoformat() }}</p>
    </div>
    <div class="summary-strip" aria-label="Build summary">
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.switches }}</span>
        <span class="summary-label">switches</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.ports }}</span>
        <span class="summary-label">ports</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.active_ports }}</span>
        <span class="summary-label">active</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.endpoints }}</span>
        <span class="summary-label">endpoints</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.missing_descriptions }}</span>
        <span class="summary-label">missing desc</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.unused_ports }}</span>
        <span class="summary-label">unused</span>
      </div>
      <div class="summary-item">
        <span class="summary-value">{{ report_summary.failed }}</span>
        <span class="summary-label">failed</span>
      </div>
    </div>
  </header>
  <nav class="quick-links" aria-label="Report sections">
    <ul>
      <li><a href="/ports/index.html">Ports</a></li>
      <li><a href="/endpoints/index.html">Endpoints</a></li>
      <li><a href="/history/index.html">History</a></li>
      <li><a href="/vlans/index.html">VLANs</a></li>
      <li><a href="/search/index.html">Search</a></li>
      <li><a href="/debug/index.html">Debug</a></li>
    </ul>
  </nav>
  <section class="panel">
    <h2>Switches</h2>
    <ul class="switch-list">
      {% for switch in switches %}
      <li>
        <a href="/switches/{{ switch.name }}.html">
          <span>{{ switch.name }}</span>
          <span class="muted">{{ switch.management_ip }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% if failed_switches %}
  <section class="panel panel-warning">
    <h2>Failed switches</h2>
    <p>Some switches failed to collect data during this build:</p>
    <ul>
      {% for switch_name in failed_switches %}
      <li>
        <strong>{{ switch_name }}</strong>
        {% if failed_switch_reasons.get(switch_name) %}
        - {{ failed_switch_reasons.get(switch_name) }}
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</body>
</html>
